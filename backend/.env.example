PORT=5000
JWT_SECRET=super_secret_skeumorphic_key

# PostgreSQL Connection Credentials
# You can supply DATABASE_URL or individual credentials
# DATABASE_URL=postgres://username:password@localhost:5432/ai_notes_db

DB_USER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_notes_db
DB_PASSWORD=your_postgres_password
DB_SSL=false

# Google Gemini API Key for note generation, text analysis, summaries and comics
GEMINI_API_KEY=your_gemini_api_key_here
